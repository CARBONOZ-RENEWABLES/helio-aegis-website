# MongoDB (Local)
MONGODB_URI=mongodb://localhost:27017/helio-aegis

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-chars-generate-with-openssl-rand-base64-32

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Resend (email)
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=admin@helioaegis.com

# Upstash Redis (rate limiting) - OPTIONAL for development
# Leave commented out to disable rate limiting in development
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# OR use local Redis (if installed)
# REDIS_URL=redis://localhost:6379

# Revalidation secret
REVALIDATE_SECRET=another-secret-key

# Admin initial setup (used by seed script only)
INITIAL_ADMIN_EMAIL=admin@helioaegis.com
INITIAL_ADMIN_PASSWORD=change-this-immediately-on-first-login
